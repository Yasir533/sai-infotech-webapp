# Backend
PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/saiinfotech?retryWrites=true&w=majority
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-password
ADMIN_EMAIL=your-email@example.com
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FAMILY=4
SMTP_REQUIRE_TLS=true
SMTP_CONNECTION_TIMEOUT=10000
SMTP_GREETING_TIMEOUT=10000
SMTP_SOCKET_TIMEOUT=10000
RESEND_API_KEY=
RESEND_FROM="SAI INFOTECH <no-reply@your-domain.com>"
ADMIN_JWT_SECRET=change-this-secret
ADMIN_RESET_JWT_SECRET=change-this-secret-too
