# ─── MySQL Database ──────────────────────────────────────────
# CHANGED: replaced MONGO_URI with these 4 MySQL variables
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=sai_infotech

# ─── Server ──────────────────────────────────────────────────
PORT=5000

# ─── Email ───────────────────────────────────────────────────
EMAIL_PROVIDER=nodemailer
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
ADMIN_EMAIL=admin@sai-infotech.com

# ─── JWT ─────────────────────────────────────────────────────
ADMIN_JWT_SECRET=your_strong_jwt_secret
ADMIN_RESET_JWT_SECRET=your_strong_reset_secret

# ─── Admin Seed ──────────────────────────────────────────────
INIT_ADMIN_PASSWORD=admin123

# ─── Cloudinary ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Optional: Resend email provider ─────────────────────────
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=your_resend_key
